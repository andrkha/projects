@startuml
left to right direction

actor "Продавец" as sel
actor "Модератор" as mod
actor "Система" as sys

rectangle "Личный кабинет продавца" {
  usecase "Заполнить карточку товара" as Заполнить
  usecase "Отправить на модерацию" as Отправить
  usecase "Редактировать товар" as Редактировать
  usecase "Снять с публикации" as Снять
  usecase "Проверить товар" as Проверить
  usecase "Одобрить публикацию" as Одобрить
  usecase "Отклонить публикацию" as Отклонить
  usecase "Уведомить о статусе" as Уведомить
}

sel --> Заполнить
sel --> Отправить
sel --> Редактировать
sel --> Снять

mod --> Проверить
Проверить ..> Одобрить : <<extend>>
Проверить ..> Отклонить : <<extend>>

sys --> Уведомить
Уведомить ..> Отправить : <<include>>
Уведомить ..> Одобрить : <<include>>
Уведомить ..> Отклонить : <<include>>

note left of Проверить
  В соответствии с правилами
end note
@enduml