  <bpmn:collaboration id="Collaboration_0zhfjum">
    <bpmn:participant id="Participant_1ytxycx" name="Компания &#34;X&#34;" processRef="Process_17ilxxv" />
    <bpmn:textAnnotation id="TextAnnotation_0n7pmu5">
      <bpmn:text>В задании не сказано что заявка создается автоматически, я предположил что человек это делает вручную</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0uqp2c8">
      <bpmn:text>Не указано как пользователь получает свой номер обращения по какому каналу</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_15auvlm">
      <bpmn:text>Предположительно, потому что не указано кто отправляет сообщение на почту или в личный кабинет</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0xzm5az">
      <bpmn:text>Вызов логистики мне показался слишком комплексным процессом для одного элемента</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_16og4a8">
      <bpmn:text>Не ясно где хранятся оценки и каким образом собираются</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_08o6oog" associationDirection="None" sourceRef="Activity_1nee1ao" targetRef="TextAnnotation_15auvlm" />
  </bpmn:collaboration>
